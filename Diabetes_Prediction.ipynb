      "source": [
        "# 9. SIMPLE WEB APP (COLAB SIMULATION): We utilize ipywidgets to create an interactive interface right inside Colab. Enter custom medical metrics to see live predictions.\n",
        "\n",
        "import ipywidgets as widgets\n",
        "from IPython.display import display, clear_output\n",
        "\n",
        "def predict_diabetes_app(btn):\n",
        "    with output:\n",
        "        clear_output()\n",
        "        input_data = np.array([[\n",
        "            pregnancies.value, glucose.value, blood_pressure.value,\n",
        "            skin_thickness.value, insulin.value, bmi.value,\n",
        "            dpf.value, age.value\n",
        "        ]])\n",
        "\n",
        "        model = joblib.load('best_diabetes_model.pkl')\n",
        "        scaler = joblib.load('diabetes_scaler.pkl')\n",
        "\n",
        "        scaled_input = scaler.transform(input_data)\n",
        "        prediction = model.predict(scaled_input)[0]\n",
        "        probability = model.predict_proba(scaled_input)[0][1]\n",
        "\n",
        "        print('\\n' + '='*40)\n",
        "        if prediction == 1:\n",
        "            print(f'⚠️ RESULT: DIABETIC')\n",
        "            print(f'Confidence: {probability*100:.2f}%')\n",
        "        else:\n",
        "            print(f'✅ RESULT: NOT DIABETIC')\n",
        "            print(f'Confidence: {(1-probability)*100:.2f}%')\n",
        "        print('='*40 + '\\n')\n",
        "\n",
        "pregnancies = widgets.FloatText(description='Pregnancies:', value=2)\n",
        "glucose = widgets.FloatText(description='Glucose:', value=120)\n",
        "blood_pressure = widgets.FloatText(description='Blood Pres.:', value=70)\n",
        "skin_thickness = widgets.FloatText(description='Skin Thick.:', value=20)\n",
        "insulin = widgets.FloatText(description='Insulin:', value=80)\n",
        "bmi = widgets.FloatText(description='BMI:', value=25.0)\n",
        "dpf = widgets.FloatText(description='DPF:', value=0.5)\n",
        "age = widgets.FloatText(description='Age:', value=33)\n",
        "\n",
        "predict_btn = widgets.Button(description='Predict Diabetes', button_style='success', icon='stethoscope')\n",
        "output = widgets.Output()\n",
        "\n",
        "predict_btn.on_click(predict_diabetes_app)\n",
        "\n",
        "print('--- 🏥 DIABETES PREDICTION SIMULATOR ---')\n",
        "print('Adjust the values below and click Predict:\\n')\n",
        "display(pregnancies, glucose, blood_pressure, skin_thickness, insulin, bmi, dpf, age, predict_btn, output)"
      ]
