      "source": [
        "# 5. MODEL TRAINING (MULTIPLE MODELS):Training base versions of Logistic Regression, Random Forest, Support Vector Machine, and XGBoost to establish baselines.\n",
        "\n",
        "models = {\n",
        "    'Logistic Regression': LogisticRegression(random_state=42, max_iter=1000),\n",
        "    'Random Forest': RandomForestClassifier(random_state=42),\n",
        "    'Support Vector Machine': SVC(random_state=42, probability=True),\n",
        "    'XGBoost': XGBClassifier(eval_metric='logloss', random_state=42)\n",
        "}\n",
        "\n",
        "base_results = {}\n",
        "print('--- Base Model Initial Training Accuracies ---')\n",
        "for name, model in models.items():\n",
        "    model.fit(X_train_scaled, y_train_res)\n",
        "    y_pred = model.predict(X_test_scaled)\n",
        "    acc = accuracy_score(y_test, y_pred)\n",
        "    base_results[name] = acc\n",
        "    print(f'{name}: {acc*100:.2f}%')"
      ]
    },
