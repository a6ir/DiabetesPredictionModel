            "Best Random Forest CV Accuracy: 90.62%\n",
            "Best XGBoost CV Accuracy: 90.75%\n"
          ]
        }
      ],
      "source": [
        "# 6. HYPERPARAMETER TUNING: Using GridSearchCV to optimize the parameters for Random Forest and XGBoost to maximize performance.\n",
        "\n",
        "print('Starting Hyperparameter Tuning...')\n",
        "\n",
        "# Tuning Random Forest\n",
        "rf_params = {\n",
        "    'n_estimators': [100, 200, 300],\n",
        "    'max_depth': [None, 10, 20],\n",
        "    'min_samples_split': [2, 5],\n",
        "    'min_samples_leaf': [1, 2]\n",
        "}\n",
        "rf_grid = GridSearchCV(RandomForestClassifier(random_state=42), rf_params, cv=5, scoring='accuracy', n_jobs=-1)\n",
        "rf_grid.fit(X_train_scaled, y_train_res)\n",
        "best_rf = rf_grid.best_estimator_\n",
        "\n",
        "# Tuning XGBoost\n",
        "xgb_params = {\n",
        "    'n_estimators': [100, 200, 300],\n",
        "    'learning_rate': [0.01, 0.05, 0.1],\n",
        "    'max_depth': [3, 5, 7],\n",
        "    'subsample': [0.8, 1.0]\n",
        "}\n",
        "xgb_grid = GridSearchCV(XGBClassifier(eval_metric='logloss', random_state=42), xgb_params, cv=5, scoring='accuracy', n_jobs=-1)\n",
        "xgb_grid.fit(X_train_scaled, y_train_res)\n",
        "best_xgb = xgb_grid.best_estimator_\n",
        "\n",
        "print('\\nTuning Complete!')\n",
        "print(f'Best Random Forest CV Accuracy: {rf_grid.best_score_*100:.2f}%')\n",
        "print(f'Best XGBoost CV Accuracy: {xgb_grid.best_score_*100:.2f}%')"
      ]
    },
